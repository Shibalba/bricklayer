[gd_scene format=3]

[sub_resource type="BoxMesh" id="BoxMesh_ground"]
size = Vector3(0.5, 0.5, 0.5)

[sub_resource type="BoxShape3D" id="BoxShape3D_ground"]
size = Vector3(0.5, 0.5, 0.5)

[sub_resource type="Shader" id="Shader_ground"]
code = "shader_type spatial;\n\nuniform vec4 grass_color : source_color = vec4(0.36, 0.73, 0.30, 1.0);\nuniform vec4 dirt_color : source_color = vec4(0.46, 0.30, 0.18, 1.0);\n\nvarying vec3 world_nrm;\n\nvoid vertex() {\n\tworld_nrm = normalize((MODEL_NORMAL_MATRIX * NORMAL));\n}\n\nvoid fragment() {\n\tvec3 n = normalize(world_nrm);\n\tvec3 base_color = dirt_color.rgb;\n\tif (n.y > 0.9) {\n\t\tbase_color = grass_color.rgb;\n\t}\n\tALBEDO = base_color;\n\tROUGHNESS = 1.0;\n\tMETALLIC = 0.0;\n}\n"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_ground"]
shader = SubResource("Shader_ground")

[node name="GroundBlock" type="StaticBody3D"]

[node name="MeshInstance3D" type="MeshInstance3D" parent="."]
mesh = SubResource("BoxMesh_ground")
material_override = SubResource("ShaderMaterial_ground")

